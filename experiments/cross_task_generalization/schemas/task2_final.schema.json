{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 2 CHILDES speaker-aware aggregation final output",
  "type": "object",
  "required": ["window_id", "speakers", "utterance_speaker_assignments", "utterance_event_counts", "events"],
  "additionalProperties": false,
  "properties": {
    "window_id": {"type": "string"},
    "speakers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pred_speaker_id", "role"],
        "additionalProperties": true,
        "properties": {
          "pred_speaker_id": {"type": "string"},
          "role": {"type": "string"}
        }
      }
    },
    "utterance_speaker_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["utt_index", "pred_speaker_id"],
        "additionalProperties": false,
        "properties": {
          "utt_index": {"type": "integer"},
          "pred_speaker_id": {"type": "string"}
        }
      }
    },
    "utterance_event_counts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "utt_index",
          "pred_speaker_id",
          "repetition_count",
          "repair_count",
          "pause_count",
          "non_speech_count",
          "overlap_count",
          "total_event_count"
        ],
        "additionalProperties": false,
        "properties": {
          "utt_index": {"type": "integer"},
          "pred_speaker_id": {"type": "string"},
          "repetition_count": {"type": "integer", "minimum": 0},
          "repair_count": {"type": "integer", "minimum": 0},
          "pause_count": {"type": "integer", "minimum": 0},
          "non_speech_count": {"type": "integer", "minimum": 0},
          "overlap_count": {"type": "integer", "minimum": 0},
          "total_event_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_type", "pred_speaker_id", "utt_index"],
        "additionalProperties": true,
        "properties": {
          "event_type": {
            "type": "string",
            "enum": ["repetition", "repair", "pause", "non_speech", "overlap"]
          },
          "pred_speaker_id": {"type": "string"},
          "utt_index": {"type": "integer"}
        }
      }
    }
  }
}
